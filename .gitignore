# agent-brief — SPA source tracked here; heavy/regenerable subdirs ignored.
agent-brief/node_modules/
agent-brief/dist/
agent-brief/.manus-logs/

# Runtime output — never committed, except the two cross-run audit files
# below. Both are tracked because each workflow run starts from a fresh
# checkout and needs to see what's already happened — without that, the
# auto-publish + x-post idempotency invariants both collapse.
#   - data/briefs.json  — publish dedupe + public-surface source of truth
#   - data/x-posts.jsonl — x-post sidecar, gates the no-double-tweet invariant
data/*
!data/briefs.json
!data/x-posts.jsonl
!data/episodes.json
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# OS / editor
.DS_Store
*.swp
*.swo

.keys