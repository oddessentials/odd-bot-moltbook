# agent-brief — SPA source tracked here; heavy/regenerable subdirs ignored.
agent-brief/node_modules/
agent-brief/dist/
agent-brief/.manus-logs/

# Runtime output — never committed, except data/briefs.json (the public-surface
# source of truth — must be tracked so the auto-publish pipeline can dedupe
# across runs and a fresh clone knows what's already published).
data/*
!data/briefs.json
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# OS / editor
.DS_Store
*.swp
*.swo
